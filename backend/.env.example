# Movent Backend — Environment Variables
# Copy this file to .env and fill in your values.

# ─── AI: Groq (primary provider) ───────────────────────────────────────────────
# Get a free API key at: https://console.groq.com
# Sign up → API Keys → Create new key
GROQ_API_KEY=your_groq_api_key_here

# ─── AI: Ollama (local fallback) ────────────────────────────────────────────────
# Install from: https://ollama.com/download
# After install, run: ollama pull llama3
# Ollama runs at http://localhost:11434 — no key needed.

# ─── Fallback ───────────────────────────────────────────────────────────────────
# If both Groq and Ollama are unavailable, the system falls back automatically
# to intelligent segment-specific mock responses (source field = "mock").

# ─── Database (optional, not used in current demo build) ────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=movent
