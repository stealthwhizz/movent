# ─── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

# ─── Secrets — real .env files only ────────────────────────────────────────────
.env
backend/.env
frontend/.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# .env.example files are safe to commit (they contain no real secrets)
!.env.example
!**/.env.example

# ─── Node / React ───────────────────────────────────────────────────────────────
node_modules/
/frontend/build/
/frontend/.pnp
/frontend/.pnp.js
/frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE ────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ───────────────────────────────────────────────────────────────────────
*.log

# ─── Emergent platform internals — not for public repo ─────────────────────────
.emergent/
memory/
test_reports/
design_guidelines.json
.gitconfig

# ─── Other secrets ──────────────────────────────────────────────────────────────
credentials.json
*.pem
*.key
.credentials
.env.*
*.env
