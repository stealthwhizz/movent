# Movent Frontend — Environment Variables
# Copy this file to .env and fill in your backend URL.

# ─── Backend API URL ────────────────────────────────────────────────────────────
# Local development (backend running on port 8001):
REACT_APP_BACKEND_URL=http://localhost:8001

# Deployed (replace with your actual deployment URL):
# REACT_APP_BACKEND_URL=https://your-deployment.example.com
